{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "rootDir": ".",
    "outDir": "dist",
    "allowJs": false,
    "esModuleInterop": true,
    "noEmitOnError": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": [
    "app.ts",
    "api/**/*.ts",
    "server.ts",
    "config/**/*.ts",
    "controller/**/*.ts",
    "model/**/*.ts",
    "route/**/*.ts",
    "types/**/*.d.ts",
    "utils/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
